# Local server/storage
PORT=3000
BSKY_AI_FEED_DB_PATH=.data/feed.sqlite
BSKY_AI_FEED_STATUS_PATH=.data/ingest-status.json

# Feed generator identity/deployment
FEEDGEN_DID=did:web:your-domain.example
FEEDGEN_SERVICE_URL=https://your-domain.example
BSKY_FEED_URI=at://did:plc:your-publisher-did/app.bsky.feed.generator/ai-feed

# Jetstream
JETSTREAM_HOST=jetstream2.us-east.bsky.network

# AI judge; do not commit real secrets in .env
AI_JUDGE_PROVIDER=openai
AI_JUDGE_MODEL=gpt-5.4-nano
AI_API_KEY=

# Publishing the feed generator record
BSKY_HANDLE=
BSKY_APP_PASSWORD=
BSKY_PDS_URL=https://bsky.social
BSKY_FEED_RKEY=ai-feed
BSKY_FEED_DISPLAY_NAME=AI Feed
BSKY_FEED_DESCRIPTION=High-signal posts about AI as a technology.
